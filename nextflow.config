// ─── Nextflow Configuration ──────────────────────────────────────────────────
// PacBio HiFi Metagenomics Pipeline
// GCP / asia-northeast3 (Seoul)

params {
    // ── Input/Output ──────────────────────────────────────────────────────────
    sample      = "sample01"
    reads       = null
    outdir      = "gs://long_reads_pacbio_template/results"

    // ── Databases (permanent in bucket) ───────────────────────────────────────
    kraken2_db      = "gs://long_reads_pacbio_template/databases/kraken2_db"
    checkm2_db      = "gs://long_reads_pacbio_template/databases/checkm2_db/CheckM2_database/uniref100.KO.1.dmnd"
    gtdbtk_db       = "gs://long_reads_pacbio_template/databases/gtdbtk_r232_db/release232"

    // ── Tool parameters ───────────────────────────────────────────────────────
    min_read_length = 1000
    min_read_quality= 20
    flye_meta       = true
    min_contig_len  = 1500
    gtdbtk_version  = "r232"

    // ── InterProScan applications (no CDD — causes H2 DB corruption) ─────────
    ipr_appl = "Pfam,TIGRFAM,SUPERFAMILY,Gene3D,PANTHER,Hamap,ProSiteProfiles"

    // ── Resource limits ───────────────────────────────────────────────────────
    max_cpus    = 32
    max_memory  = "256.GB"
    max_time    = "24.h"
}

// ─── GCP Profile ──────────────────────────────────────────────────────────────
profiles {
    gcp {
        process.executor        = "google-batch"
        google.project          = "project-60508a53-5845-4238-877"
        google.location         = "asia-northeast3"
        google.batch.spot       = false   // preemptible = cheaper
        workDir                 = "gs://long_reads_pacbio_template/nextflow_work"
    }

    // Local testing profile (Cloud Shell)
    local {
        process.executor = "local"
        docker.enabled   = false
    }
}

// ─── Process resource allocation ──────────────────────────────────────────────
process {
    // Default
    cpus   = 4
    memory = "16.GB"
    disk   = "50.GB"

    // Stage 1 — QC
    withName: 'QC_RAW' {
        cpus   = 4
        memory = "16.GB"
        disk   = "100.GB"
        machineType = "n2-standard-4"
    }

    // Stage 2 — Assembly (Flye)
    withName: 'ASSEMBLY' {
        cpus   = 16
        memory = "128.GB"
        disk = "300.GB"
        diskType = "pd-standard"
        machineType = "n2-highmem-16"
        time = "48.h"
    }

    // Stage 3 — Taxonomy (Kraken2)
    withName: 'KRAKEN2' {
        cpus   = 8
        memory = "32.GB"
        disk   = "100.GB"
        machineType = "n2-standard-4"
    }

    // Stage 4 — Binning (Minimap2 + MetaBAT2 + MaxBin2 + CONCOCT + DAS Tool)
    withName: 'MINIMAP2' {
        cpus   = 32
        memory = "64.GB"
        disk   = "300.GB"
        diskType = "pd-standard"
        machineType = "n2-standard-32"
        time   = "12.h"
    }

    // Stage 5 — CheckM2
    withName: 'CHECKM2' {
        cpus   = 16
        memory = "32.GB"
        disk   = "100.GB"
        machineType = "n2-standard-16"
    }

    // Stage 6 — CoverM
    withName: 'COVERM' {
        cpus   = 8
        memory = "32.GB"
        disk   = "100.GB"
        machineType = "n2-standard-4"
    }

    // Stage 7a — GTDB-tk (needs 256GB for pplacer!)
    withName: 'GTDBTK' {
        cpus   = 32
        memory = "256.GB"
        disk   = "200.GB"
        diskType = "pd-standard"
        machineType = "n2-highmem-32"
        time   = "6.h"
    }

    // Stage 7b — Prodigal
    withName: 'PRODIGAL' {
        cpus   = 4
        memory = "16.GB"
        disk   = "50.GB"
        machineType = "n2-standard-4"
    }

    // Stage 7c — InterProScan (HQ)
    withName: 'INTERPROSCAN_HQ' {
        cpus   = 8
        memory = "64.GB"
        disk   = "100.GB"
        machineType = "n2-highmem-8"
        time   = "6.h"
    }

    // Stage 7c — InterProScan (MQ)
    withName: 'INTERPROSCAN_MQ' {
        cpus   = 8
        memory = "64.GB"
        disk   = "100.GB"
        machineType = "n2-highmem-8"
        time   = "4.h"
    }

    // Stage 8 — Excel Report
    withName: 'REPORT' {
        cpus   = 2
        memory = "8.GB"
        disk   = "50.GB"
        machineType = "n2-standard-2"
    }
}

// ─── Execution settings ───────────────────────────────────────────────────────
executor {
    queueSize       = 10    // max parallel jobs
    pollInterval    = "30s"
    submitRateLimit = "5/1min"
}

// ─── Retry on preemption ──────────────────────────────────────────────────────
process.errorStrategy = { task.exitStatus in [14, 50, 143, 137] ? "retry" : "finish" }
process.maxRetries    = 3

// ─── Reports ──────────────────────────────────────────────────────────────────
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace.txt"
}

// ─── Manifest ─────────────────────────────────────────────────────────────────
manifest {
    name        = "longread-metagenomics"
    author      = "Darsha"
    description = "PacBio HiFi metagenomics pipeline — GCP"
    version     = "1.0.0"
    nextflowVersion = ">=25.0.0"
}
    samplesheet = null

// ─── File staging ─────────────────────────────────────────────────────────────
process.stageInMode = 'copy'
google.batch.maxSpotAttempts = 3

// Allow overwriting existing reports
report.overwrite   = true
timeline.overwrite = true
trace.overwrite    = true
